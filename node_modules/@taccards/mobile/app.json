{
  "expo": {
    "name": "TacCards Vault",
    "slug": "taccards-vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#534AB7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.taccards.vault",
      "infoPlist": {
        "NSCameraUsageDescription": "Usiamo la fotocamera per scansionare le tue carte collezionabili",
        "NSPhotoLibraryUsageDescription": "Usiamo la galleria per importare immagini delle carte"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#534AB7"
      },
      "package": "com.taccards.vault",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-camera", { "cameraPermission": "Usiamo la fotocamera per scansionare le tue carte" }]
    ],
    "scheme": "taccards",
    "extra": {
      "eas": { "projectId": "DA-COMPILARE-DOPO-EAS-INIT" }
    }
  }
}
