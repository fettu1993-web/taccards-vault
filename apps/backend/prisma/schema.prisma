generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// UTENTI
// ─────────────────────────────────────────
model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  displayName        String?   @map("display_name")
  avatarUrl          String?   @map("avatar_url")
  subscriptionTier   String    @default("free") @map("subscription_tier")
  isPremium          Boolean   @default(false) @map("is_premium")
  stripeCustomerId   String?   @map("stripe_customer_id")
  stripeSubId        String?   @map("stripe_sub_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  userCards          UserCard[]
  sealedProducts     SealedProduct[]
  scanLogs           ScanLog[]
  watchlist          Watchlist[]

  @@map("users")
}

// ─────────────────────────────────────────
// CATALOGO CARTE (globale, condiviso)
// ─────────────────────────────────────────
model Card {
  id           String   @id @default(uuid())
  name         String
  playerName   String?  @map("player_name")
  team         String?
  sport        String
  category     String
  manufacturer String?
  setName      String   @map("set_name")
  year         Int
  cardNumber   String?  @map("card_number")
  parallel     String?
  isRookie     Boolean  @default(false) @map("is_rookie")
  isAutograph  Boolean  @default(false) @map("is_autograph")
  isNumbered   Boolean  @default(false) @map("is_numbered")
  printRun     Int?     @map("print_run")
  imageUrl     String?  @map("image_url")
  externalId   String?  @map("external_id")
  dataSource   String   @default("manual") @map("data_source")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userCards    UserCard[]
  priceHistory PriceHistory[]
  scanLogs     ScanLog[]
  watchlist    Watchlist[]

  @@index([sport, year])
  @@index([playerName])
  @@index([externalId])
  @@map("cards")
}

// ─────────────────────────────────────────
// COLLEZIONE UTENTE
// ─────────────────────────────────────────
model UserCard {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  cardId           String    @map("card_id")
  condition        String    @default("raw")
  gradeCompany     String?   @map("grade_company")
  gradeValue       String?   @map("grade_value")
  certNumber       String?   @map("cert_number")
  purchasePrice    Decimal?  @map("purchase_price") @db.Decimal(10, 2)
  purchaseDate     DateTime? @map("purchase_date")
  purchasePlatform String?   @map("purchase_platform")
  status           String    @default("in_collection")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])

  @@index([userId])
  @@index([cardId])
  @@map("user_cards")
}

// ─────────────────────────────────────────
// STORICO PREZZI (motore grafici)
// ─────────────────────────────────────────
model PriceHistory {
  id         String   @id @default(uuid())
  cardId     String   @map("card_id")
  gradeLabel String   @map("grade_label")
  price      Decimal  @db.Decimal(10, 2)
  source     String
  platform   String?
  saleDate   DateTime @map("sale_date")
  fetchedAt  DateTime @default(now()) @map("fetched_at")

  card Card @relation(fields: [cardId], references: [id])

  @@index([cardId, gradeLabel])
  @@index([saleDate])
  @@map("price_history")
}

// ─────────────────────────────────────────
// PRODOTTI SIGILLATI (sealed box / case)
// ─────────────────────────────────────────
model SealedProduct {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  name             String
  category         String
  productType      String   @map("product_type")
  manufacturer     String?
  year             Int
  setName          String   @map("set_name")
  quantity         Int      @default(1)
  purchasePrice    Decimal  @map("purchase_price") @db.Decimal(10, 2)
  purchaseDate     DateTime @map("purchase_date")
  purchasePlatform String?  @map("purchase_platform")
  currentValue     Decimal? @map("current_value") @db.Decimal(10, 2)
  status           String   @default("sealed")
  notes            String?
  imageUrl         String?  @map("image_url")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  priceHistory SealedPriceHistory[]

  @@index([userId])
  @@index([category, year])
  @@map("sealed_products")
}

// ─────────────────────────────────────────
// STORICO PREZZI SEALED
// ─────────────────────────────────────────
model SealedPriceHistory {
  id              String        @id @default(uuid())
  sealedProductId String        @map("sealed_product_id")
  price           Decimal       @db.Decimal(10, 2)
  source          String
  saleDate        DateTime      @map("sale_date")
  fetchedAt       DateTime      @default(now()) @map("fetched_at")

  sealedProduct SealedProduct @relation(fields: [sealedProductId], references: [id], onDelete: Cascade)

  @@index([sealedProductId])
  @@map("sealed_price_history")
}

// ─────────────────────────────────────────
// LOG SCANSIONI
// ─────────────────────────────────────────
model ScanLog {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  matchedCardId   String?  @map("matched_card_id")
  imageUrl        String?  @map("image_url")
  apiProvider     String?  @map("api_provider")
  confidenceScore Decimal? @map("confidence_score") @db.Decimal(5, 4)
  wasConfirmed    Boolean  @default(false) @map("was_confirmed")
  scannedAt       DateTime @default(now()) @map("scanned_at")

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchedCard Card? @relation(fields: [matchedCardId], references: [id])

  @@index([userId])
  @@map("scan_logs")
}

// ─────────────────────────────────────────
// WATCHLIST / PRICE ALERTS
// ─────────────────────────────────────────
model Watchlist {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  cardId      String   @map("card_id")
  targetPrice Decimal? @map("target_price") @db.Decimal(10, 2)
  notifyAbove Boolean  @default(false) @map("notify_above")
  notifyBelow Boolean  @default(true) @map("notify_below")
  gradeLabel  String?  @map("grade_label")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
  @@map("watchlist")
}